<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme.Dialog.Alert" parent="@style/Theme.MaterialComponents.Dialog.Alert">
        <item name="android:backgroundTint">@color/material_grey_850</item>
        <item name="android:backgroundTintMode">src_atop</item>
    </style>

    <style name="AppTheme" parent="android:Theme.Holo">
        <item name="android:alertDialogTheme">@style/AppTheme.Dialog.Alert</item>
        <item name="android:buttonStyle">@style/Button</item>
        <item name="android:imageButtonStyle">@android:style/Widget.Holo.Light.ImageButton</item>
        <item name="android:spinnerItemStyle">@style/TextViewSpinnerItem</item>
        <item name="android:spinnerDropDownItemStyle">@style/TextViewSpinnerDropDownItem</item>
        <item name="android:windowBackground">@android:color/black</item>
    </style>

    <style name="Button" parent="@android:style/Widget.Holo.Light.Button">
        <item name="android:textColor">@android:color/primary_text_dark</item>
    </style>

    <style name="Monospaced" parent="AppTheme">
        <item name="android:fontFamily">monospace</item>
        <item name="android:spinnerDropDownItemStyle">@style/TextViewSpinnerDropDownItemMonospace</item>
    </style>

    <style name="AppDialog" parent="@android:style/Theme.Holo.Dialog">
        <item name="android:alertDialogTheme">@style/AppTheme.Dialog.Alert</item>
        <item name="android:spinnerDropDownItemStyle">@style/TextViewSpinnerDropDownItem</item>
    </style>

    <style name="AppCompatDialog" parent="@style/Theme.AppCompat.Dialog">
        <item name="android:alertDialogTheme">@style/AppTheme.Dialog.Alert</item>
        <item name="android:windowBackground">@android:color/black</item>
    </style>

    <style name="AppThemeCompat.Dialog" parent="Theme.AppCompat.Dialog">
        <item name="android:windowBackground">@color/material_grey_900</item>
    </style>

    <style name="AppThemeCompat.Dialog.Alert" parent="Theme.AppCompat.Dialog.Alert">
        <item name="android:windowBackground">@color/material_grey_900</item>
    </style>

    <style name="AppThemeCompat" parent="@style/Theme.AppCompat.NoActionBar">
        <item name="android:dialogTheme">@style/AppThemeCompat.Dialog</item>
        <item name="android:alertDialogTheme">@style/AppThemeCompat.Dialog.Alert</item>
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:navigationBarColor">@color/background_material_dark</item>

        <item name="android:fastScrollThumbDrawable">@drawable/thumb_drawable</item>
        <item name="android:fastScrollTrackDrawable">@drawable/line_drawable</item>
    </style>

    <style name="Caption" parent="@style/TextAppearance.AppCompat.Caption">
        <item name="android:textColor">?android:attr/textColorSecondary</item>
    </style>

    <style name="Synonym" parent="@style/TextAppearance.AppCompat.Caption">
        <item name="android:textColor">?android:attr/textColorTertiary</item>
    </style>

    <style name="LightSpinner" parent="@style/AppTheme">
        <item name="android:spinnerItemStyle">@style/LightSpinnerItem</item>
    </style>

    <style name="LightSpinnerItem" parent="Widget.AppCompat.TextView.SpinnerItem">
        <item name="android:textColor">@android:color/primary_text_light</item>
    </style>
</resources>