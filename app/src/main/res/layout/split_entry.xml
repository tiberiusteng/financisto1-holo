<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/top_layout"
    android:paddingRight="?android:attr/scrollbarSize"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="@dimen/select_entry_height"
    android:background="?android:attr/listChoiceBackgroundIndicator">

    <TextView
        android:id="@+id/indicator"
        android:layout_width="4sp"
        android:layout_height="0dp"
        android:layout_marginStart="1sp"
        android:background="@color/unreconciled_transaction_color"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <TextView android:id="@+id/label"
        android:layout_height="wrap_content"
        android:layout_width="0dp"
        android:layout_marginStart="3sp"
        android:text="label"
        android:textAppearance="@style/ListPrimary"
        android:textColor="@android:color/secondary_text_dark"
        android:maxLines="1" android:ellipsize="end"
        app:layout_constraintStart_toEndOf="@id/indicator"
        app:layout_constraintEnd_toStartOf="@id/data"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <TextView
        android:id="@+id/data"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:text="data"
        android:textAppearance="@style/ListPrimary"
        android:textColor="@android:color/primary_text_dark"
        app:layout_constraintBaseline_toBaselineOf="@id/label"
        app:layout_constraintEnd_toStartOf="@id/end" />

    <FrameLayout
        android:id="@+id/end"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <ImageView style="@style/MinusButton"
            android:layout_width="wrap_content"
            android:id="@+id/plus_minus"
            android:layout_height="wrap_content"
            android:focusable="true"
            android:clickable="true"
            android:paddingTop="4dp" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>